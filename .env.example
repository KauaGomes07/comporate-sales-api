# Exemplo de variáveis de ambiente para desenvolvimento
# NÃO adicione segredos reais neste arquivo

# URL de conexão do MongoDB (substitua pelos seus dados)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster0.mongodb.net/<database>?retryWrites=true&w=majority"

# Segredo para assinar tokens JWT (use um valor forte em produção)
JWT_SECRET="sua_chave_secreta_aqui"

# Porta do servidor (opcional)
PORT=3000
